<Window x:Class="CaravanCMS.Admin.Views.ScanFilesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CaravanCMS.Admin.ViewModels"
        Title="Scan &amp; Link Documents"
        Height="680" Width="900"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackground}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="Scan &amp; Link Documents" Style="{StaticResource HeadingLarge}"/>
            <TextBlock Text="Scans the Caravan History folder for PDFs and images, then matches each file to a caravan record."
                       Style="{StaticResource SubText}" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Controls -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Style="{StaticResource InputBox}"
                             Text="{Binding CustomFolderPath, UpdateSourceTrigger=PropertyChanged}"/>

                    <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                            Content="Browse" Margin="8,0,8,0" Click="BrowseFolder_Click"/>

                    <Button Grid.Column="2" Style="{StaticResource PrimaryButton}"
                            Content="▶  Start Scan" Command="{Binding StartScanCommand}"
                            MinWidth="120"/>
                </Grid>

                <ProgressBar Style="{StaticResource PinkProgress}" Margin="0,0,0,8"
                             IsIndeterminate="True"
                             Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}"/>

                <TextBlock Text="{Binding ProgressText}" Style="{StaticResource SubText}"
                           TextWrapping="Wrap" Margin="0,0,0,6"/>

                <TextBlock Text="{Binding ResultSummary}" Style="{StaticResource BodyText}"
                           FontWeight="SemiBold"
                           Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </Border>

        <!-- Results DataGrid -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0"
                Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Files found:" Style="{StaticResource BodyText}"
                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Select All"
                            Command="{Binding SelectAllCommand}" Padding="10,5" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource SecondaryButton}" Content="Select None"
                            Command="{Binding SelectNoneCommand}" Padding="10,5" Margin="0,0,12,0"/>
                    <TextBlock Style="{StaticResource SubText}" VerticalAlignment="Center"
                               Text="{Binding SelectedCount, StringFormat='{}{0} selected for linking'}"/>
                </StackPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Files}"
                          Style="{StaticResource PinkDataGrid}"
                          ColumnHeaderStyle="{StaticResource PinkDataGridColumnHeader}"
                          IsReadOnly="False">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Link"
                                                Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                Width="50" IsReadOnly="False"/>
                        <DataGridTextColumn Header="File"          Binding="{Binding File.FileName}"  Width="160" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Source Folder" Binding="{Binding SourceFolder}"   Width="*"   IsReadOnly="True"/>

                        <!-- Caravan picker — shows suggested match, allows override via dropdown -->
                        <DataGridTemplateColumn Header="Caravan" Width="220">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SelectedDisplay}"
                                               VerticalAlignment="Center" Margin="4,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedCaravan}" Value="{x:Null}">
                                                        <Setter Property="Text" Value="— click to assign —"/>
                                                        <Setter Property="Foreground" Value="#AAAAAA"/>
                                                        <Setter Property="FontStyle" Value="Italic"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.AllCaravans,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedItem="{Binding SelectedCaravan, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMemberPath="RegistrationNumber"
                                              IsEditable="False"
                                              IsDropDownOpen="True"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Method"     Binding="{Binding File.MatchMethod}"    Width="110" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Confidence" Binding="{Binding ConfidenceDisplay}"   Width="75"  IsReadOnly="True"/>
                        <DataGridCheckBoxColumn Header="Linked" Binding="{Binding IsLinked}"
                                                Width="55" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Action buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Style="{StaticResource PrimaryButton}" Content="🔗  Link Selected"
                    Command="{Binding LinkSelectedCommand}" Margin="0,0,10,0"
                    Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}"/>
            <Button Style="{StaticResource SecondaryButton}" Content="Close"
                    IsCancel="True" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
