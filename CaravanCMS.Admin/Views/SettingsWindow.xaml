<Window x:Class="CaravanCMS.Admin.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CaravanCMS — Settings"
        Height="440" Width="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackground}">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="Settings" Style="{StaticResource HeadingLarge}"/>
            <TextBlock Text="Configure the API connection and file paths."
                       Style="{StaticResource SubText}"/>
        </StackPanel>

        <!-- Fields -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0">
            <StackPanel>
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="API Endpoint" Style="{StaticResource BodyText}"
                               FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtApiUrl" Style="{StaticResource InputBox}"
                             Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="API Key" Style="{StaticResource BodyText}"
                               FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="PwdApiKey" Height="36"
                                 FontFamily="Segoe UI" FontSize="13" Padding="10,7"
                                 BorderBrush="{StaticResource BorderPink}" BorderThickness="1.5"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="Caravan History Folder" Style="{StaticResource BodyText}"
                               FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtFolderPath" Style="{StaticResource InputBox}"
                                 Text="{Binding CaravanHistoryPath, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                Content="Browse" Click="BrowseFolder_Click"/>
                    </Grid>
                </StackPanel>

                <!-- Connection test result -->
                <Border x:Name="TestResultBorder" CornerRadius="6" Padding="12,8"
                        Background="{StaticResource LightPink}" Visibility="Collapsed">
                    <TextBlock x:Name="TxtTestResult" Style="{StaticResource BodyText}"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="Test Connection"
                    Click="TestConnection_Click" Margin="0,0,8,0"/>
            <Button Style="{StaticResource SecondaryButton}" Content="Cancel"
                    IsCancel="True" Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Style="{StaticResource PrimaryButton}" Content="Save Settings"
                    IsDefault="True" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
