<Window x:Class="CaravanCMS.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CaravanCMS.Client"
        Icon="Resources/client.ico"
        Title="CaravanCMS — Caravan History"
        Height="680" Width="1000"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackground}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseVisibilityConverter x:Key="InverseVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource DeepPink}">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="CaravanCMS" FontFamily="Segoe UI" FontSize="22"
                               FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Caravan Service History Viewer" FontFamily="Segoe UI"
                               FontSize="11" Foreground="#FFDDEE"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                           FontFamily="Segoe UI" FontSize="12" Foreground="#FFDDEE"
                           VerticalAlignment="Center" MaxWidth="300" TextWrapping="Wrap"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- ── Content ─────────────────────────────────────────────────────── -->
        <Grid Grid.Row="1">

            <!-- ╔══════════════════════════════════════════╗ -->
            <!-- ║  LOOKUP PANEL  (default / startup view)  ║ -->
            <!-- ╚══════════════════════════════════════════╝ -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding IsLookupMode, Converter={StaticResource BoolToVis}}">

                <!-- List All Caravans -->
                <Button Style="{StaticResource SecondaryButton}"
                        Content="☰   List All Caravans"
                        Command="{Binding ShowListCommand}"
                        HorizontalAlignment="Center"
                        Padding="22,9" FontSize="13"
                        Margin="0,0,0,36"/>

                <!-- ── Registration Plate ─────────────────────────────────── -->
                <Border Width="680" Height="200"
                        Background="White"
                        BorderBrush="#111111" BorderThickness="7"
                        CornerRadius="10"
                        ClipToBounds="True"
                        HorizontalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="28" ShadowDepth="6"
                                          Opacity="0.20" Color="#000000" Direction="270"/>
                    </Border.Effect>

                    <!-- Rego input -->
                    <TextBox x:Name="RegoBox"
                             Text="{Binding RegoQuery, UpdateSourceTrigger=PropertyChanged}"
                             CharacterCasing="Upper"
                             MaxLength="8"
                             FontFamily="Bahnschrift" FontSize="96" FontWeight="Bold"
                             Foreground="#111111"
                             Background="Transparent"
                             BorderThickness="0"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Center"
                             HorizontalContentAlignment="Center"
                             Margin="24,0"
                             KeyDown="RegoBox_KeyDown">
                        <TextBox.Resources>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </Border>

                <!-- Find button -->
                <Button Style="{StaticResource PrimaryButton}"
                        Content="Find Caravan"
                        Command="{Binding LookupRegoCommand}"
                        HorizontalAlignment="Center"
                        Padding="32,12" FontSize="14"
                        Margin="0,22,0,0"/>

                <!-- Error / not-found message -->
                <TextBlock Text="{Binding LookupStatus}"
                           Style="{StaticResource SubText}"
                           HorizontalAlignment="Center"
                           FontSize="13"
                           Foreground="{StaticResource ErrorBrush}"
                           Margin="0,14,0,0"
                           Visibility="{Binding HasLookupStatus, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <!-- ╔══════════════════════════════════════════╗ -->
            <!-- ║  LIST PANEL  (all caravans / search)     ║ -->
            <!-- ╚══════════════════════════════════════════╝ -->
            <Grid Visibility="{Binding IsLookupMode, Converter={StaticResource InverseVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search bar -->
                <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderPink}"
                        BorderThickness="0,0,0,1" Padding="20,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Style="{StaticResource SecondaryButton}"
                                Content="← Plate Lookup"
                                Command="{Binding ShowLookupCommand}"
                                Margin="0,0,12,0"/>

                        <TextBox Grid.Column="1" x:Name="TxtSearch"
                                 Style="{StaticResource SearchBox}"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="SearchBox_KeyDown"/>

                        <Button Grid.Column="2" Style="{StaticResource PrimaryButton}"
                                Content="Search" Margin="10,0,0,0" MinWidth="90"
                                Command="{Binding SearchCommand}"/>
                    </Grid>
                </Border>

                <!-- Results area -->
                <Grid Grid.Row="1" Margin="20,16,20,0">

                    <!-- Loading indicator -->
                    <TextBlock Text="Loading..." Style="{StaticResource SubText}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="16"
                               Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}"/>

                    <!-- Empty state -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding HasResults, Converter={StaticResource InverseVis}}">
                        <TextBlock Text="🔍" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding StatusText}" Style="{StaticResource SubText}"
                                   HorizontalAlignment="Center" FontSize="14"/>
                    </StackPanel>

                    <!-- Results DataGrid — double-click row to open detail -->
                    <DataGrid x:Name="ResultsGrid"
                              ItemsSource="{Binding SearchResults}"
                              Style="{StaticResource PinkDataGrid}"
                              ColumnHeaderStyle="{StaticResource PinkDataGridColumnHeader}"
                              MouseDoubleClick="Results_DoubleClick"
                              Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Make"         Binding="{Binding Make}"               Width="90"/>
                            <DataGridTextColumn Header="Model"        Binding="{Binding Model}"              Width="120"/>
                            <DataGridTextColumn Header="Year"         Binding="{Binding Year}"               Width="55"/>
                            <DataGridTextColumn Header="Colour"       Binding="{Binding Color}"              Width="80"/>
                            <DataGridTextColumn Header="Registration" Binding="{Binding RegistrationNumber}" Width="100"/>
                            <DataGridTextColumn Header="VIN"          Binding="{Binding Vin}"                Width="130"/>
                            <DataGridTextColumn Header="Customer"     Binding="{Binding CustomerName}"       Width="*"/>
                            <DataGridTextColumn Header="Last Job"
                                                Binding="{Binding LastJobDate, StringFormat='dd MMM yyyy'}" Width="100"/>
                            <DataGridTextColumn Header="Jobs"  Binding="{Binding JobCount}"      Width="50"/>
                            <DataGridTextColumn Header="Docs"  Binding="{Binding DocumentCount}" Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Grid>

        <!-- ── Status bar ──────────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="{StaticResource LightPink}"
                BorderBrush="{StaticResource BorderPink}" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <TextBlock Text="{Binding StatusText}" Style="{StaticResource SubText}" VerticalAlignment="Center"/>
                <TextBlock Text="Double-click a row to view full history" Style="{StaticResource SubText}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Visibility="{Binding IsLookupMode, Converter={StaticResource InverseVis}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
