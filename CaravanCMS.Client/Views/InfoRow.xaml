<UserControl x:Class="CaravanCMS.Client.Views.InfoRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="LabelText" FontFamily="Segoe UI" FontSize="12"
                   Foreground="#7A6A6A" VerticalAlignment="Center"/>
        <TextBlock x:Name="ValueText" Grid.Column="1" FontFamily="Segoe UI"
                   FontSize="12" Foreground="#2C2424" VerticalAlignment="Center"
                   TextWrapping="Wrap"/>
    </Grid>
</UserControl>
